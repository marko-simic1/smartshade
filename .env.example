PORT=3000

# ─── Home Assistant instance (login po stanaru) ───────────────────────────────
# Svaki stanar ima svoj HA instance. stanar1 → ha1, stanar2 → ha2 (vidi server/index.js).
# Admin vidi sve instance. Bez tokena instanca prikazuje samo virtualne sobe (simulator).

# Instanca 1 (stanar1) — nosi i 10 virtualnih soba simulatora po defaultu
HA1_BASE_URL=http://192.168.1.10:8123
HA1_TOKEN=<long-lived-access-token-prve-VM>
HA1_LABEL=Zgrada A
# HA1_VIRTUAL=true

# Instanca 2 (stanar2) — druga HA VM
HA2_BASE_URL=http://192.168.1.20:8123
HA2_TOKEN=<long-lived-access-token-druge-VM>
HA2_LABEL=Zgrada B
HA2_VIRTUAL=false

MQTT_BROKER=test.mosquitto.org
MQTT_PORT=1883
